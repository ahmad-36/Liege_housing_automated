# Copy this file to .env and fill in your own values.
# The Streamlit UI (streamlit run app.py) can also write this file for you
# via the "Credentials" tab. Never commit the real .env to git.

# KotaLiège account (register free at https://www.kotaliege.be/_register_)
KOTALIEGE_EMAIL=
KOTALIEGE_PASSWORD=

# Gmail for ULiège outreach emails.
# Use an App Password from https://myaccount.google.com/apppasswords
# (requires 2-step verification — your normal password will NOT work).
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_DISPLAY_NAME=
